{
  "name": "routstrd",
  "version": "0.1.5",
  "module": "src/index.ts",
  "type": "module",
  "private": false,
  "bin": {
    "routstrd": "./dist/index.js"
  },
  "scripts": {
    "start": "bun src/index.ts start",
    "monitor": "bun src/index.ts monitor",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "build": "mkdir -p dist/daemon && bun build src/index.ts --target=bun --outfile=dist/index.js && bun build src/daemon/index.ts --target=bun --outfile=dist/daemon/index.js",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^3.1.1",
    "@routstr/sdk": "^0.2.7",
    "applesauce-core": "^5.1.0",
    "applesauce-relay": "^5.1.0",
    "commander": "^14.0.2",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.1",
    "zustand": "^5.0.5"
  }
}
